{
  "name": "@beside/runtime",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "pnpm --filter @beside/core run build && tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "clean": "rimraf dist *.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node scripts/smoke-meetings.mjs && pnpm run build && node scripts/smoke-events.mjs && node scripts/smoke-journal-story.mjs"
  },
  "dependencies": {
    "@beside/core": "workspace:*",
    "@beside/interfaces": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "sharp": "^0.33.5",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "typescript": "^5.6.3"
  }
}
