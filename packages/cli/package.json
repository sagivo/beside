{
  "name": "@cofounderos/cli",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cofounderos": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist *.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "cross-env COFOUNDEROS_DEV=1 tsx watch --clear-screen=false --exclude \"**/dist/**\" --conditions=development src/cli.ts start",
    "test": "echo \"(no tests)\""
  },
  "dependencies": {
    "@cofounderos/core": "workspace:*",
    "@cofounderos/runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.4",
    "@types/screenshot-desktop": "^1.12.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
