{
  "name": "@cofounderos/desktop",
  "version": "0.2.0",
  "private": true,
  "description": "Desktop interface for CofounderOS local memory capture and journals.",
  "author": "CofounderOS",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build:main": "pnpm --filter @cofounderos/runtime run build && tsc -p tsconfig.json && node scripts/copy-preload.mjs && bash scripts/build-native.sh",
    "build": "pnpm run build:main && vite build",
    "prepare:package": "node scripts/build-icons.mjs && pnpm --dir ../.. build:plugins && node scripts/prepare-package-resources.mjs",
    "package": "pnpm run build && pnpm run prepare:package && electron-builder --dir",
    "dist": "pnpm run build && pnpm run prepare:package && electron-builder",
    "clean": "rimraf dist *.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.renderer.json",
    "start": "pnpm run build && electron dist/main.js",
    "dev": "node scripts/dev.mjs"
  },
  "dependencies": {
    "@cofounderos/core": "workspace:*",
    "@cofounderos/runtime": "workspace:*",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.10"
  },
  "build": {
    "appId": "com.cofounderos.desktop",
    "productName": "CofounderOS",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/resources/cofounderos",
        "to": "cofounderos"
      }
    ],
    "mac": {
      "target": [
        "dir"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "dir"
      ],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [
        "dir"
      ],
      "icon": "build/icon.png",
      "category": "Utility"
    }
  }
}
