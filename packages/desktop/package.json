{
  "name": "@cofounderos/desktop",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "pnpm --filter @cofounderos/runtime run build && tsc -p tsconfig.json && node scripts/copy-preload.mjs && vite build && bash scripts/build-native.sh",
    "clean": "rimraf dist *.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "pnpm run build && electron dist/main.js",
    "dev": "pnpm run start"
  },
  "dependencies": {
    "@cofounderos/core": "workspace:*",
    "@cofounderos/runtime": "workspace:*",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.4.0",
    "vite": "^8.0.10"
  }
}
