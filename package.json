{
  "name": "cofounderos",
  "version": "0.2.0",
  "private": true,
  "description": "AI-powered device capture, knowledge indexing, and agent memory system.",
  "license": "MIT",
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter \"@cofounderos/*\" run build",
    "clean": "pnpm -r --filter \"@cofounderos/*\" run clean && rm -rf node_modules",
    "typecheck": "pnpm -r --filter \"@cofounderos/*\" run typecheck",
    "dev": "pnpm --filter @cofounderos/app run dev",
    "cli": "node packages/app/dist/cli.js",
    "index:run": "pnpm cli index --once",
    "index:reorg": "pnpm cli index --reorganise",
    "index:reindex": "pnpm cli index --full-reindex",
    "test": "pnpm -r --filter \"@cofounderos/*\" run test"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sharp",
      "esbuild",
      "active-win"
    ]
  }
}
