{
  "name": "cofounderos",
  "version": "0.2.0",
  "private": true,
  "description": "AI-powered device capture, knowledge indexing, and agent memory system.",
  "license": "MIT",
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter \"@cofounderos/*\" run build && node scripts/build-plugins.mjs",
    "build:plugins": "node scripts/build-plugins.mjs",
    "clean": "pnpm -r --filter \"@cofounderos/*\" run clean && rimraf node_modules \"plugins/*/*/dist\" \"plugins/*/*/.tsbuildinfo\"",
    "typecheck": "pnpm -r --filter \"@cofounderos/*\" run typecheck",
    "start": "pnpm desktop",
    "dev": "pnpm --filter @cofounderos/desktop run dev",
    "dev:cli": "pnpm build && pnpm --filter @cofounderos/cli run dev",
    "desktop": "pnpm --filter @cofounderos/desktop run start",
    "desktop:dev": "pnpm --filter @cofounderos/desktop run dev",
    "desktop:package": "pnpm --filter @cofounderos/desktop run package",
    "desktop:dist": "pnpm --filter @cofounderos/desktop run dist",
    "daemon": "pnpm cli start",
    "cli": "node packages/cli/dist/cli.js",
    "index:run": "pnpm cli index --once",
    "index:reorg": "pnpm cli index --reorganise",
    "index:reindex": "pnpm cli index --full-reindex",
    "test": "pnpm -r --filter \"@cofounderos/*\" run test"
  },
  "devDependencies": {
    "@cofounderos/core": "workspace:*",
    "@cofounderos/interfaces": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.4",
    "@types/screenshot-desktop": "^1.12.3",
    "active-win": "^9.0.0",
    "better-sqlite3": "^11.3.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "ollama": "^0.5.9",
    "rimraf": "^6.1.3",
    "screenshot-desktop": "^1.15.4",
    "sharp": "^0.33.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "zod": "^3.23.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sharp",
      "esbuild",
      "active-win"
    ]
  }
}
