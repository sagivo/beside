{
  "name": "native",
  "version": "0.2.0",
  "layer": "capture",
  "interface": "ICapture",
  "entrypoint": "dist/index.js",
  "description": "Native sidecar capture plugin. A TypeScript ICapture shim launches a platform-specific helper binary that emits RawEvent NDJSON.",
  "config_schema": {
    "type": "object",
    "properties": {
      "helper_path": { "type": "string" },
      "fixture": { "type": "boolean", "default": false },
      "restart_on_crash": { "type": "boolean", "default": true },
      "poll_interval_ms": { "type": "integer", "default": 3000 },
      "idle_poll_interval_ms": { "type": "integer", "default": 30000 },
      "focus_settle_delay_ms": { "type": "integer", "default": 900 },
      "screenshot_diff_threshold": { "type": "number", "default": 0.15 },
      "idle_threshold_sec": { "type": "integer" },
      "screenshot_format": { "type": "string", "enum": ["webp", "jpeg"], "default": "webp" },
      "screenshot_quality": { "type": "integer", "default": 45 },
      "screenshot_max_dim": { "type": "integer", "default": 1100 },
      "content_change_min_interval_ms": { "type": "integer", "default": 60000 },
      "excluded_apps": { "type": "array", "items": { "type": "string" } },
      "excluded_url_patterns": { "type": "array", "items": { "type": "string" } },
      "capture_audio": { "type": "boolean", "default": true },
      "audio": {
        "type": "object",
        "properties": {
          "inbox_path": { "type": "string" },
          "live_recording": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean", "default": true },
              "chunk_seconds": { "type": "integer", "default": 300 },
              "format": { "type": "string", "enum": ["m4a"], "default": "m4a" },
              "sample_rate": { "type": "integer", "default": 16000 },
              "channels": { "type": "integer", "default": 1 },
              "system_audio_backend": {
                "type": "string",
                "enum": ["core_audio_tap", "screencapturekit", "off"],
                "default": "core_audio_tap"
              },
              "activation": {
                "type": "string",
                "enum": ["other_process_input", "always"],
                "default": "other_process_input",
                "description": "Use other_process_input. Legacy always values are accepted for old configs but treated as input-only by the native helper."
              },
              "poll_interval_sec": { "type": "integer", "default": 3 }
            }
          }
        }
      },
      "multi_screen": { "type": "boolean", "default": false },
      "screens": { "type": "array", "items": { "type": "integer", "minimum": 0 } },
      "capture_mode": { "type": "string", "enum": ["all", "active"], "default": "active" }
    }
  }
}
